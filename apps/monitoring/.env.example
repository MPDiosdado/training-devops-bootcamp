# MyFitness Monitoring - Variables de Entorno
# Bootcamp DevOps 2026 | Carlos Palanca - T-Systems

# Aplicacion
FRONTEND_PORT=3000
BACKEND_PORT=3001

# Monitoreo
GRAFANA_PORT=3002
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
PROMETHEUS_PORT=9090

# Notas:
# http://localhost:3000     -> Frontend MyFitness
# http://localhost:3001     -> Backend API + /metrics
# http://localhost:3002     -> Grafana (admin/admin)
# http://localhost:9090     -> Prometheus
# http://localhost:9100     -> Node Exporter
