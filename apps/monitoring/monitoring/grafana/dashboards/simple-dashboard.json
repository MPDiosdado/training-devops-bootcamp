{
  "id": null,
  "title": "MyFitness - Dashboard de Monitoreo",
  "tags": ["devops", "prometheus", "myfitness", "bootcamp"],
  "style": "dark",
  "timezone": "",
  "refresh": "30s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 100,
      "title": "ESTADO GENERAL DE SERVICIOS",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1,
      "title": "Estado de Servicios",
      "type": "stat",
      "targets": [
        {
          "expr": "up{job=\"myfitness-backend\"}",
          "legendFormat": "Backend API",
          "refId": "A"
        },
        {
          "expr": "up{job=\"prometheus\"}",
          "legendFormat": "Prometheus",
          "refId": "B"
        },
        {
          "expr": "up{job=\"node-exporter\"}",
          "legendFormat": "Node Exporter",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            {
              "options": {
                "0": { "text": "CAIDO" },
                "1": { "text": "OK" }
              },
              "type": "value"
            }
          ]
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "background"
      },
      "gridPos": { "h": 6, "w": 18, "x": 0, "y": 1 }
    },
    {
      "id": 2,
      "title": "Uptime de la App",
      "type": "stat",
      "targets": [
        {
          "expr": "app_uptime_seconds{job=\"myfitness-backend\"}",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s"
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "textMode": "value_and_name",
        "colorMode": "value"
      },
      "gridPos": { "h": 3, "w": 6, "x": 18, "y": 1 }
    },
    {
      "id": 3,
      "title": "Rate de Errores Global",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"myfitness-backend\", status_code=~\"4..|5..\"}[5m])) / sum(rate(http_requests_total{job=\"myfitness-backend\"}[5m])) * 100",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 3, "w": 6, "x": 18, "y": 4 }
    },
    {
      "id": 200,
      "title": "MYFITNESS BACKEND - PERFORMANCE",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 }
    },
    {
      "id": 4,
      "title": "Requests por Segundo",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"myfitness-backend\"}[5m]))",
          "legendFormat": "RPS",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 8 }
    },
    {
      "id": 5,
      "title": "Latencia Promedio",
      "type": "stat",
      "targets": [
        {
          "expr": "avg(rate(http_request_duration_seconds_sum{job=\"myfitness-backend\"}[5m]) / rate(http_request_duration_seconds_count{job=\"myfitness-backend\"}[5m])) * 1000",
          "legendFormat": "Avg Latency",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 8 }
    },
    {
      "id": 6,
      "title": "Latencia P95",
      "type": "stat",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"myfitness-backend\"}[5m])) by (le)) * 1000",
          "legendFormat": "P95 Latency",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 1000 }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 8 }
    },
    {
      "id": 7,
      "title": "Throughput por Endpoint",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"myfitness-backend\"}[5m])) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    },
    {
      "id": 8,
      "title": "Latencia por Percentil",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"myfitness-backend\"}[5m])) by (le)) * 1000",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"myfitness-backend\"}[5m])) by (le)) * 1000",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"myfitness-backend\"}[5m])) by (le)) * 1000",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 }
    },
    {
      "id": 9,
      "title": "Distribucion de Status Codes",
      "type": "piechart",
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{job=\"myfitness-backend\"}[5m])) by (status_code)",
          "legendFormat": "{{status_code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "pieType": "pie",
        "tooltip": { "mode": "single" },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["percent", "value"]
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
    },
    {
      "id": 300,
      "title": "BASE DE DATOS - EJERCICIOS",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 }
    },
    {
      "id": 11,
      "title": "Total de Ejercicios",
      "type": "stat",
      "targets": [
        {
          "expr": "database_exercises_total{job=\"myfitness-backend\"}",
          "legendFormat": "Ejercicios",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 21 }
    },
    {
      "id": 12,
      "title": "Crecimiento de Ejercicios",
      "type": "timeseries",
      "targets": [
        {
          "expr": "database_exercises_total{job=\"myfitness-backend\"}",
          "legendFormat": "Total Ejercicios",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 21 }
    },
    {
      "id": 13,
      "title": "Operaciones CRUD de Ejercicios",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"myfitness-backend\", endpoint=~\"/api/exercises.*\", method=\"POST\"}[5m]))",
          "legendFormat": "Creados/seg",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"myfitness-backend\", endpoint=~\"/api/exercises.*\", method=\"GET\"}[5m]))",
          "legendFormat": "Consultados/seg",
          "refId": "B"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"myfitness-backend\", endpoint=~\"/api/exercises.*\", method=\"PUT\"}[5m]))",
          "legendFormat": "Actualizados/seg",
          "refId": "C"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"myfitness-backend\", endpoint=~\"/api/exercises.*\", method=\"DELETE\"}[5m]))",
          "legendFormat": "Eliminados/seg",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 21 }
    },
    {
      "id": 400,
      "title": "INFRAESTRUCTURA - SISTEMA",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 }
    },
    {
      "id": 14,
      "title": "CPU del Servidor",
      "type": "gauge",
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 30 }
    },
    {
      "id": 15,
      "title": "Memoria del Servidor",
      "type": "gauge",
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "Memory %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 30 }
    },
    {
      "id": 16,
      "title": "Tendencias de CPU y Memoria",
      "type": "timeseries",
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        },
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "Memory %",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 }
    },
    {
      "id": 500,
      "title": "TOP RANKINGS Y ANALISIS",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 }
    },
    {
      "id": 17,
      "title": "Top Endpoints Mas Usados",
      "type": "bargauge",
      "targets": [
        {
          "expr": "topk(10, sum(rate(http_requests_total{job=\"myfitness-backend\"}[5m])) by (endpoint))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps"
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "list"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 }
    },
    {
      "id": 18,
      "title": "Endpoints con Mas Errores",
      "type": "bargauge",
      "targets": [
        {
          "expr": "topk(5, sum(rate(http_requests_total{job=\"myfitness-backend\", status_code=~\"4..|5..\"}[5m])) by (endpoint))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.1 }
            ]
          },
          "unit": "reqps"
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "list"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 }
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "links": [],
  "version": 1
}
